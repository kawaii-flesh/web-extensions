{
    "manifest_version": 2,
    "name": "Remove FBclid and UTM",
    "version": "2.0",
    "description": "Removes fbclid, ysclid, gclid, and utm_ query parameters in URLs.",
    "icons": {
        "48": "icons/noFbclidUtmIcon.png"
    },
    "permissions": [
        "storage",
        "webRequest",
        "webRequestBlocking",
        "http://*/*",
        "https://*/*"
    ],
    "background": {
        "scripts": [
            "defaults.js",
            "background.js"
        ]
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "queryParamsRemover@kawaii-flesh.git.com",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "browser_action": {
        "default_icon": "icons/noFbclidUtmIcon.png",
        "default_title": "URL Cleaner",
        "default_popup": "popup.html"
    }
}